# === Application Settings ===
APP_NAME=SecRAG
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# === FastAPI Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# === OIDC/JWT Authentication ===
# Keycloak: http://keycloak:8080/realms/secrag
# Azure AD: https://login.microsoftonline.com/{tenant-id}
OIDC_ISSUER_URL=http://localhost:8080/realms/secrag
OIDC_CLIENT_ID=secrag-client
OIDC_CLIENT_SECRET=your-secret-key-here
JWT_ALGORITHM=RS256
JWT_EXPIRATION_HOURS=8

# === Qdrant Vector Database ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=secrag
QDRANT_VECTOR_SIZE=384  # Dimension of embeddings (e.g., sentence-transformers/all-MiniLM-L6-v2)

# === Redis Caching & Rate Limiting ===
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL_SECONDS=86400  # 24 hours
REDIS_SESSION_TTL_SECONDS=28800  # 8 hours

# === LLM Configuration ===
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

LLM_TEMPERATURE=0.0  # Deterministic responses
LLM_MAX_TOKENS=1024

# === Embedding Model ===
# Using sentence-transformers (runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# === LangSmith Tracing ===
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=secrag-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# === Safety & Guardrails ===
PII_REDACTION_ENABLED=True

# === Ingestion Settings ===
# Trust score formula: base_tier + recency_factor + authority_weight
TRUST_SCORE_MIN_THRESHOLD=1.5  # Chunks below this are quarantined

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=10  # Per user, per minute
RATE_LIMIT_TOKENS_PER_DAY=100000  # Per user, per day

# === Department Quotas (tokens per day) ===
DEPT_FINANCE_QUOTA=500000
DEPT_HR_QUOTA=100000
DEPT_STANDARD_QUOTA=50000

# === Observability & Logging ===
STRUCTURED_LOGGING=True  # JSON format
LOG_TO_STDOUT=True

# === AWS S3 (for Qdrant backups) ===
# Used in DR strategy (see Section 9 of SYSTEM_DESIGN.md)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=secrag-backups
QDRANT_SNAPSHOT_SCHEDULE=0 2 * * *  # Daily at 02:00 UTC

# === Email / Alerts ===
# For cost alerts (US-503) and incident notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_EMAIL_RECIPIENTS=ops@company.com

# === Development / Testing ===
SQLALCHEMY_ECHO=False
PYTEST_ASYNCIO_MODE=auto
TESTING=False
